# Flask
SECRET_KEY=genereaza-un-secret-lung-si-aleator
# Local (fara HTTPS) seteaza 0; in productie lasa 1.
COOKIE_SECURE=1

# PostgreSQL (Railway o seteaza automat pe addon)
DATABASE_URL=postgresql://user:parola@localhost:5432/journal

# Autentificare (un singur utilizator)
JOURNAL_USER=numele-tau
# Genereaza cu: flask create-password-hash <parola>
JOURNAL_PASSWORD_HASH=$2b$12$...

# Cloudflare R2
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=journal
# Optional; daca lipseste se deriva din R2_ACCOUNT_ID
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
